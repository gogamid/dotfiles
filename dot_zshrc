# oh-my-zsh
export ZSH="$HOME/.oh-my-zsh"
ZSH_THEME="robbyrussell"
DISABLE_AUTO_UPDATE="true" # chezmoi handles it
plugins=(
	zsh-autosuggestions
	zsh-syntax-highlighting
	zsh-vi-mode
	tmux
)

# tmux
ZSH_TMUX_FIXTERM_WITH_256COLOR=true

#zsh-vi-mode
ZVM_VI_HIGHLIGHT_BACKGROUND=#37393B

export EDITOR=nvim
export VISUAL=nvim
export LANG=en_US.UTF-8

export NEOVIDE_FRAME=buttonless

path() {
	export PATH=$PATH:$1
}

# brew
path "/opt/homebrew/bin" 
# reinstall pip-system-certs after azure-cli upgrade
brew() {
  command brew "$@"
  case "$*" in
    *upgrade*|*update*|*reinstall*|*install*)
      if command brew list azure-cli &>/dev/null 2>&1; then
        AZ_VER=$(ls /opt/homebrew/Cellar/azure-cli/ 2>/dev/null | tail -1)
        AZ_PY="/opt/homebrew/Cellar/azure-cli/$AZ_VER/libexec/bin/python"
        [ -f "$AZ_PY" ] && "$AZ_PY" -m pip install pip-system-certs -q 2>/dev/null && echo "✓ pip-system-certs reinstalled for Azure CLI"
      fi
      ;;
  esac
}

# Oracle client and other manually installed tools
path $HOME/.local/bin/

#paths
path "$HOME/context/tex/texmf-osx-arm64/bin"
path "/opt/homebrew/opt/make/libexec/gnubin"
path "/opt/homebrew/opt/libpq/bin"

# go
path $HOME/go/bin

# rust
path $HOME/.cargo/bin


# WezTerm
path /Applications/WezTerm.app/Contents/MacOS


# node
path ./node_modules/.bin

# dotnet
export DOTNET_ROOT="/opt/homebrew/opt/dotnet@6/libexec"

#zoxide
eval "$(zoxide init --cmd cd zsh)"

# bun
export BUN_INSTALL="$HOME/.bun"
path "$BUN_INSTALL/bin"
[ -s "/Users/gamidli/.bun/_bun" ] && source "/Users/gamidli/.bun/_bun"

# opencode
path /Users/gamidli/.opencode/bin

# android / java
export ANT_HOME=/opt/homebrew/opt/ant
export MAVEN_HOME=/opt/homebrew/opt/maven
export GRADLE_HOME=/opt/homebrew/opt/gradle
export ANDROID_HOME="$HOME/Library/Android/sdk"
export JAVA_HOME="$(brew --prefix openjdk)/libexec/openjdk.jdk/Contents/Home"
path "$JAVA_HOME/bin"
path "$ANDROID_HOME/cmdline-tools/latest/bin"
path "$ANDROID_HOME/platform-tools"
path "$ANDROID_HOME/emulator"
path "$ANDROID_HOME/build-tools/37.0.0"

if [  -f ~/.workZSH.sh ]; then
	source ~/.workZSH.sh
fi

if [  -f ~/.aliases.sh ]; then
	source ~/.aliases.sh
fi

source $ZSH/oh-my-zsh.sh

export ORACLE_HOME=/opt/homebrew
path /opt/homebrew/share/google-cloud-sdk/bin

