# True color (important for tmux + fzf)
term = xterm-256color
# auto-update-channel = tip
# theme = light:bohemian-light,dark:bohemian-dark
theme = light:zenbones-light,dark:zenbones-dark
# background-opacity = 0.87
# background-blur-radius = true
# cursor-opacity = 1
# cursor-invert-fg-bg = true
# cursor-style-blink = true
mouse-hide-while-typing = true
macos-titlebar-style = hidden
font-size = 13
link-url = true
selection-clear-on-copy = true
copy-on-select = clipboard


# ---------- Key behavior ----------
# Let tmux handle keybindings
# keybind = ctrl+l=unbind
# keybind = global:ctrl+,=toggle_quick_terminal
quick-terminal-position = center
quick-terminal-screen = mouse
quick-terminal-animation-duration = 0
quick-terminal-size = 50%,70%

font-family = "JetBrainsMonoNL Nerd Font Mono"
macos-option-as-alt = true
